# ローカル backend 開発時
# VITE_DEV_BACKEND_URL=http://127.0.0.1:8000

# フロントのみローカル・backend は AWS ECS のとき（推奨）
VITE_DEV_BACKEND_URL=http://syodan-alb-xxxxx.ap-northeast-1.elb.amazonaws.com
# VITE_WS_BASE_URL は未設定時 VITE_API_BASE_URL から自動導出 (http→ws, https→wss)

# AWS ALB 接続時（フロントは localhost:5173、バックエンドは AWS）
# VITE_API_BASE_URL=https://syodan-alb-xxxxx.ap-northeast-1.elb.amazonaws.com
# VITE_WS_BASE_URL は省略可（上記から wss:// が自動導出される）
